<view class="page settings-page">
  <!-- 词库设置 -->
  <view class="card section">
    <view class="section-title">词库设置</view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">大学英语四级（2500词）</view>
      </view>
      <view class="item-right">
        <view class="radio {{settings.level==='CET4'?'checked':''}}" data-level="CET4" bindtap="switchLevel">
          <view wx:if="{{settings.level==='CET4'}}" class="check">✓</view>
        </view>
      </view>
    </view>
    <view class="divider"></view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">大学英语六级（2000词）</view>
      </view>
      <view class="item-right">
        <view class="radio {{settings.level==='CET6'?'checked':''}}" data-level="CET6" bindtap="switchLevel">
          <view wx:if="{{settings.level==='CET6'}}" class="check">✓</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 学习设置 -->
  <view class="card section">
    <view class="section-title">学习设置</view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">每日学习目标</view>
        <view class="desc">当前目标：{{settings.dailyGoal}} 个单词/天</view>
      </view>
    </view>
    <view class="slider-wrap">
      <slider min="10" max="100" step="10" value="{{settings.dailyGoal}}" bindchange="onGoalChange" bindchanging="onGoalChanging" show-value activeColor="#5B7CFA" backgroundColor="#E6E8F0" />
    </view>
    <view class="divider"></view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">自动播放发音</view>
        <view class="desc">学习时自动播放单词发音</view>
      </view>
      <view class="item-right">
        <switch checked="{{settings.autoPlayAudio}}" bindchange="onAutoPlayChange" color="#5B7CFA" />
      </view>
    </view>
  </view>

  <!-- 提醒设置 -->
  <view class="card section">
    <view class="section-title">提醒设置</view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">每日提醒</view>
        <view class="desc">每天定时提醒学习</view>
      </view>
      <view class="item-right">
        <switch checked="{{settings.reminderEnabled}}" bindchange="onReminderSwitch" color="#5B7CFA" />
      </view>
    </view>
    <view wx:if="{{settings.reminderEnabled}}" class="setting-item">
      <view class="item-left">
        <view class="label">提醒时间</view>
      </view>
      <view class="item-right">
        <picker mode="time" value="{{settings.reminderTime}}" bindchange="onReminderTimeChange">
          <view class="picker-text">{{settings.reminderTime}}</view>
        </picker>
      </view>
    </view>
  </view>

  <!-- 数据管理 -->
  <view class="card section">
    <view class="section-title">数据管理</view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">导出学习数据</view>
        <view class="desc">导出学习记录和生词本</view>
      </view>
      <button class="btn-export" bindtap="exportData">导出为JSON</button>
    </view>
    <view class="divider"></view>
    <view class="setting-item">
      <view class="item-left">
        <view class="label">清空学习记录</view>
        <view class="desc">将删除所有学习记录，不可恢复</view>
      </view>
      <button class="btn-clear" bindtap="clearData">清空所有数据</button>
    </view>
  </view>

  <!-- 关于 -->
  <view class="card section">
    <view class="section-title">关于</view>
    <view class="about-item">
      <view class="about-label">版本号</view>
      <view class="about-value">v1.0.0</view>
    </view>
    <view class="divider"></view>
    <view class="about-item">
      <view class="about-label">开发者</view>
      <view class="about-value">词汇通团队</view>
    </view>
    <view class="divider"></view>
    <view class="about-item">
      <view class="about-label">项目介绍</view>
      <view class="about-value">一个专注于四六级单词学习的小程序</view>
    </view>
  </view>
</view>
