.wordbook-page { min-height: 100vh; background: #F5F7FF; padding-bottom: 140rpx; }
.top { padding: 28rpx; }
.title { font-size: 36rpx; font-weight: 800; }
.subtitle { color: #8A8F9C; margin-top: 8rpx; }
.tabs { margin-top: 16rpx; display: flex; gap: 16rpx; }
.tab { padding: 10rpx 20rpx; border-radius: 30rpx; color: #666; background: #ECEFF7; }
.tab.active { background: #5B7CFA; color: #fff; }

.empty { padding: 80rpx 28rpx; display: flex; flex-direction: column; align-items: center; color: #8A8F9C; }
.empty .emoji { font-size: 80rpx; margin-bottom: 12rpx; }
.empty .tip { margin-bottom: 16rpx; }

.container { padding: 0 28rpx 28rpx; }
.card { background: #fff; border-radius: 20rpx; box-shadow: 0 8rpx 24rpx rgba(36,46,66,0.08); }
.item { padding: 22rpx; margin-bottom: 20rpx; }
.row { display: flex; justify-content: space-between; gap: 16rpx; }
.main { flex: 1; min-width: 0; }
.word { font-size: 36rpx; font-weight: 800; color: #111; }
.phonetic { color: #8A8F9C; margin-top: 6rpx; font-size: 26rpx; }
.translation { margin-top: 8rpx; font-size: 30rpx; color: #333; }
.meta { margin-top: 8rpx; color: #8A8F9C; font-size: 24rpx; }
.actions { display: flex; align-items: center; }
.speak { width: 72rpx; height: 72rpx; border-radius: 36rpx; background: #5B7CFA; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 32rpx; box-shadow: 0 6rpx 16rpx rgba(91,124,250,0.35); }
.speak:active { transform: scale(0.95); }

.expand { margin-top: 16rpx; padding-top: 16rpx; border-top: 2rpx solid #F0F2F8; }
.example { font-size: 26rpx; color: #555; }
.example.cn { color: #8A8F9C; margin-top: 8rpx; }
.exp-actions { margin-top: 16rpx; display: flex; justify-content: flex-end; }

.footer { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; box-shadow: 0 -8rpx 20rpx rgba(0,0,0,0.06); padding: 16rpx 28rpx 28rpx; }
.btn-hero { display: flex; align-items: center; justify-content: center; height: 88rpx; border-radius: 50rpx; color: #fff; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-weight: 700; }
.btn-outline { display: inline-flex; align-items: center; justify-content: center; height: 72rpx; border-radius: 40rpx; color: #4C5BD4; background: #E9ECFF; font-weight: 700; padding: 0 24rpx; }


