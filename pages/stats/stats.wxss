.stats-page { background: #F5F7FF; padding: 24rpx; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }
.card { background: #fff; border-radius: 20rpx; box-shadow: 0 8rpx 24rpx rgba(36,46,66,0.08); }
.stat-card { padding: 24rpx; }
.label { color: #8A8F9C; font-size: 24rpx; }
.num { font-size: 44rpx; font-weight: 800; color: #5B7CFA; margin-top: 8rpx; }
.unit { color: #8A8F9C; font-size: 24rpx; margin-left: 6rpx; }

.chart { margin-top: 24rpx; padding: 24rpx; }
.chart-title { font-weight: 700; margin-bottom: 16rpx; }
.chart-placeholder { padding: 40rpx 0; text-align: center; }
.placeholder-text { font-size: 32rpx; color: #666; margin-bottom: 12rpx; }
.placeholder-desc { font-size: 24rpx; color: #999; margin-bottom: 24rpx; }
.placeholder-data { margin-top: 24rpx; }
.data-item { padding: 12rpx 0; display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f0f0f0; }
.data-item:last-child { border-bottom: none; }
.data-date { color: #666; font-size: 26rpx; }
.data-count { color: #5B7CFA; font-weight: 600; font-size: 28rpx; }

.achievements { margin-top: 24rpx; padding: 24rpx; }
.badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.badge { border-radius: 16rpx; padding: 16rpx; display: flex; flex-direction: column; align-items: center; text-align: center; }
.badge.on { background: #EEF2FF; }
.badge.off { background: #F2F3F5; opacity: 0.9; }
.badge .icon { font-size: 48rpx; }
.badge .name { margin-top: 6rpx; font-weight: 700; }
.badge .desc { color: #8A8F9C; font-size: 22rpx; }


